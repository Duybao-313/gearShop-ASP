@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Quên mật khẩu</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow border-0">
                    <div class="card-header bg-warning text-dark text-center py-3">
                        <h5 class="mb-0">QUÊN MẬT KHẨU</h5>
                    </div>
                    <div class="card-body p-4">
                        @if (!string.IsNullOrEmpty(ViewBag.Message))
                        {
                            <div class="alert alert-success py-2">
                                <strong>@ViewBag.Message</strong>
                            </div>
                            if (!string.IsNullOrEmpty(ViewBag.ResetLink))
                            {
                                <div class="alert alert-info py-2">
                                    <small>Link reset:</small><br />
                                    <a href="@ViewBag.ResetLink" class="text-break">@ViewBag.ResetLink</a>
                                </div>
                                <p class="text-muted small mt-3">
                                    <em>Trong môi trường thực tế, link này sẽ được gửi qua email.</em>
                                </p>
                            }
                        }
                        else
                        {
                            <p class="text-muted small">Nhập tên đăng nhập của bạn, chúng tôi sẽ tạo link đặt lại mật khẩu.</p>
                            <form asp-action="ForgotPassword" method="post">
                                <div class="mb-3">
                                    <label class="form-label">Tên đăng nhập</label>
                                    <input type="text" name="username" class="form-control" required placeholder="Nhập tên đăng nhập..." />
                                </div>
                                @if (!string.IsNullOrEmpty(ViewBag.Error))
                                {
                                    <div class="alert alert-danger py-2">@ViewBag.Error</div>
                                }
                                <button type="submit" class="btn btn-warning w-100">GỬI YÊU CẦU</button>
                            </form>
                        }
                        <div class="text-center mt-3">
                            <a href="/Account/Login">← Quay lại đăng nhập</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
