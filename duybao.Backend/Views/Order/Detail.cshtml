@model duybao.data.Entities.Order

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.Id}";
}

<div class="container-fluid mt-3">
    @* ─── Thông báo ─── *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ─── Header ─── *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-2">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </a>
            <h3><i class="bi bi-receipt"></i> Chi tiết đơn hàng <span class="badge bg-secondary">#@Model.Id</span></h3>
        </div>
        <div>
            @switch (Model.Status)
            {
                case 0:
                    <span class="badge bg-warning text-dark fs-6 px-3 py-2">⏳ Chờ duyệt</span>
                    break;
                case 1:
                    <span class="badge bg-primary fs-6 px-3 py-2">🚚 Đang giao</span>
                    break;
                case 2:
                    <span class="badge bg-success fs-6 px-3 py-2">✅ Đã xong</span>
                    break;
            }
        </div>
    </div>

    <div class="row">
        @* ─── Cột trái: Thông tin đơn hàng & khách hàng ─── *@
        <div class="col-md-5">
            @* Thông tin đơn hàng *@
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Thông tin đơn hàng</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm table-borderless">
                        <tr>
                            <td class="fw-bold" style="width: 100px;">Mã đơn:</td>
                            <td><span class="badge bg-secondary">#@Model.Id</span></td>
                        </tr>
                        <tr>
                            <td class="fw-bold">Ngày đặt:</td>
                            <td>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        </tr>
                        <tr>
                            <td class="fw-bold">Trạng thái:</td>
                            <td>
                                @switch (Model.Status)
                                {
                                    case 0: <span class="badge bg-warning text-dark">⏳ Chờ duyệt</span>; break;
                                    case 1: <span class="badge bg-primary">🚚 Đang giao</span>; break;
                                    case 2: <span class="badge bg-success">✅ Đã xong</span>; break;
                                }
                            </td>
                        </tr>
                        @if (!string.IsNullOrEmpty(Model.Notes))
                        {
                            <tr>
                                <td class="fw-bold">Ghi chú:</td>
                                <td><small class="text-muted">@Model.Notes</small></td>
                            </tr>
                        }
                    </table>
                </div>
            </div>

            @* Thông tin khách hàng *@
            @if (Model.Customer != null)
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="bi bi-person"></i> Thông tin khách hàng</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm table-borderless">
                            <tr>
                                <td class="fw-bold" style="width: 100px;">Họ tên:</td>
                                <td><strong>@Model.Customer.FullName</strong></td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Email:</td>
                                <td>@Model.Customer.Email</td>
                            </tr>
                            @if (!string.IsNullOrEmpty(Model.Customer.Phone))
                            {
                                <tr>
                                    <td class="fw-bold">SĐT:</td>
                                    <td>@Model.Customer.Phone</td>
                                </tr>
                            }
                            @if (!string.IsNullOrEmpty(Model.Customer.Address))
                            {
                                <tr>
                                    <td class="fw-bold">Địa chỉ:</td>
                                    <td>@Model.Customer.Address</td>
                                </tr>
                            }
                        </table>
                    </div>
                </div>
            }

            @* Thông tin tài khoản liên kết *@
            @if (Model.User != null)
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="bi bi-link-45deg"></i> Tài khoản liên kết</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm table-borderless">
                            <tr>
                                <td class="fw-bold" style="width: 100px;">Username:</td>
                                <td>@Model.User.Username</td>
                            </tr>
                            <tr>
                                <td class="fw-bold">Vai trò:</td>
                                <td><span class="badge bg-secondary">@Model.User.Role</span></td>
                            </tr>
                        </table>
                    </div>
                </div>
            }

            @* Form cập nhật trạng thái *@
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-arrow-repeat"></i> Cập nhật trạng thái</h5>
                </div>
                <div class="card-body">
                    <form asp-action="UpdateStatus" method="post" class="row g-2 align-items-end">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="col-md-7">
                            <label class="form-label fw-bold small">Trạng thái mới</label>
                            <select name="newStatus" class="form-select">
                                <option value="0" selected="@(Model.Status == 0 ? "selected" : null)">⏳ Chờ duyệt</option>
                                <option value="1" selected="@(Model.Status == 1 ? "selected" : null)">🚚 Đang giao</option>
                                <option value="2" selected="@(Model.Status == 2 ? "selected" : null)">✅ Đã xong</option>
                            </select>
                        </div>
                        <div class="col-md-5">
                            <button type="submit" class="btn btn-warning w-100">
                                <i class="bi bi-check-lg"></i> Cập nhật
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @* ─── Cột phải: Danh sách sản phẩm ─── *@
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-box-seam"></i> Sản phẩm trong đơn hàng
                        @if (Model.OrderDetails != null)
                        {
                            <span class="badge bg-light text-dark ms-2">@Model.OrderDetails.Count() sản phẩm</span>
                        }
                    </h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.OrderDetails == null || !Model.OrderDetails.Any())
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            <p>Không có sản phẩm nào trong đơn hàng.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 60px;">Ảnh</th>
                                        <th>Sản phẩm</th>
                                        <th class="text-end">Đơn giá</th>
                                        <th class="text-center">SL</th>
                                        <th class="text-end">Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        decimal grandTotal = 0;
                                        int totalQty = 0;
                                    }
                                    @foreach (var detail in Model.OrderDetails)
                                    {
                                        var lineTotal = detail.Quantity * detail.UnitPrice;
                                        grandTotal += lineTotal;
                                        totalQty += detail.Quantity;
                                        <tr>
                                            <td>
                                                @if (detail.Product != null && !string.IsNullOrEmpty(detail.Product.ImageUrl))
                                                {
                                                    <img src="@detail.Product.ImageUrl" alt="@detail.Product.Name"
                                                         style="width: 50px; height: 50px; object-fit: cover; border-radius: 6px;" />
                                                }
                                                else
                                                {
                                                    <div class="bg-light d-flex align-items-center justify-content-center"
                                                         style="width: 50px; height: 50px; border-radius: 6px;">
                                                        <i class="bi bi-image text-muted"></i>
                                                    </div>
                                                }
                                            </td>
                                            <td>
                                                <strong>@(detail.Product?.Name ?? "Sản phẩm không xác định")</strong>
                                                @if (detail.Product != null)
                                                {
                                                    <br />
                                                    <small class="text-muted">
                                                        @detail.Product.Brand
                                                        @if (!string.IsNullOrEmpty(detail.Product.Sku))
                                                        {
                                                            <span>| SKU: @detail.Product.Sku</span>
                                                        }
                                                    </small>
                                                }
                                            </td>
                                            <td class="text-end">@detail.UnitPrice.ToString("N0") ₫</td>
                                            <td class="text-center">
                                                <span class="badge bg-secondary">@detail.Quantity</span>
                                            </td>
                                            <td class="text-end">
                                                <strong class="text-danger">@lineTotal.ToString("N0") ₫</strong>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-dark">
                                    <tr>
                                        <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                                        <td class="text-center">
                                            <span class="badge bg-light text-dark fs-6">@totalQty</span>
                                        </td>
                                        <td class="text-end">
                                            <strong class="text-warning fs-5">@grandTotal.ToString("N0") ₫</strong>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @* ─── Nút xóa đơn hàng ─── *@
            <div class="text-end mt-3">
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Bạn có chắc muốn XÓA đơn hàng #@Model.Id? Hành động này không thể hoàn tác!')"
                      style="display:inline;">
                    <button type="submit" class="btn btn-outline-danger">
                        <i class="bi bi-trash"></i> Xóa đơn hàng này
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert-dismissible');
            alerts.forEach(function(alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
}
