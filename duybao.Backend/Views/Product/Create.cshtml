@model duybao.data.Entities.Product

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-box-seam"></i> THÊM SẢN PHẨM MỚI</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên sản phẩm:</label>
                            <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô tả sản phẩm:</label>
                            <textarea asp-for="Description" class="form-control" rows="6" placeholder="Nhập mô tả sản phẩm..."></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Giá sản phẩm (VNĐ):</label>
                                <input asp-for="Price" class="form-control" placeholder="0" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Giảm giá (%):</label>
                                <input asp-for="DiscountPercentage" class="form-control" placeholder="0" type="number" step="0.01" min="0" max="100" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-bold">Số lượng tồn kho:</label>
                                <input asp-for="StockQuantity" class="form-control" placeholder="0" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Thương hiệu:</label>
                                <input asp-for="Brand" class="form-control" placeholder="Logitech, Razer, Corsair..." />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Mã SKU:</label>
                                <input asp-for="Sku" class="form-control" placeholder="LOG-GPX-001" />
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Danh mục sản phẩm:</label>
                            <select asp-for="CategoryProductId" class="form-select" asp-items="ViewBag.CategoryProductList">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ảnh đại diện (URL):</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Danh sách ảnh bổ sung (mỗi dòng 1 URL):</label>
                            <textarea name="ImagesText" class="form-control" rows="5" placeholder="https://cdn.dummyjson.com/.../1.webp&#10;https://cdn.dummyjson.com/.../2.webp&#10;https://cdn.dummyjson.com/.../3.webp"></textarea>
                            <small class="text-muted">Mỗi dòng 1 link ảnh. Hỗ trợ import từ DummyJSON.</small>
                            <input type="hidden" asp-for="Images" />
                        </div>

                        <hr />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-cloud-arrow-up"></i> Lưu sản phẩm
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại danh sách
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
