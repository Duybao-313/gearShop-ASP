@model IEnumerable<duybao.data.Entities.Product>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-dark">DANH SÁCH SẢN PHẨM</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm sản phẩm mới
        </a>
    </div>

    <!-- Thanh tìm kiếm / lọc theo danh mục -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold">Danh mục sản phẩm</label>
                    <select name="id" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Tất cả danh mục --</option>
                        @foreach (var cat in (IEnumerable<duybao.data.Entities.CategoryProduct>)ViewBag.CategoryProductListAll)
                        {
                            bool isSelected = ViewBag.CategoryFilterId != null && (int)ViewBag.CategoryFilterId == cat.Id;
                            <!option value="@cat.Id" selected=@isSelected>@cat.Name</!option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Bỏ lọc</a>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm">
                    <img src="@item.ImageUrl" class="card-img-top" alt="Thumbnail" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <span class="badge bg-info text-dark">@item.CategoryProduct?.Name</span>
                        @if (!string.IsNullOrEmpty(item.Brand))
                        {
                            <span class="badge bg-secondary">@item.Brand</span>
                        }
                        @if (item.DiscountPercentage > 0)
                        {
                            <span class="badge bg-danger">-@item.DiscountPercentage%</span>
                        }
                        <h5 class="card-title text-primary mt-1">@item.Name</h5>
                        <p class="card-text text-truncate">@item.Description</p>
                        <p class="text-success fw-bold">@string.Format("{0:N0} VNĐ", item.Price)</p>
                        <p class="text-muted small">
                            <span>⭐ @item.Rating.ToString("0.0")</span> &nbsp;|&nbsp;
                            Tồn kho: @item.StockQuantity
                        </p>
                        <a href="/Product/Details/@item.Id" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                            <i class="bi bi-pencil"></i> Sửa
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-sm btn-outline-danger"
                           onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này không?')">
                            <i class="bi bi-trash"></i> Xóa
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @{
        int currentPage = ViewBag.CurrentPage ?? 1;
        int totalPages = ViewBag.TotalPages ?? 1;
        int? catId = ViewBag.CategoryFilterId;
    }

    <!-- Phân trang -->
    @if (totalPages > 1)
    {
        <nav aria-label="Phân trang sản phẩm">
            <div class="d-flex justify-content-between align-items-center mt-3 mb-4">
                <div class="text-muted small">
                    Trang @currentPage / @totalPages
                </div>
                <ul class="pagination mb-0">
                    @{
                        // Nút Previous
                        string prevUrl = Url.Action("Index", new { id = catId, page = currentPage - 1 });
                    }
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" href="@prevUrl" aria-label="Trước">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>

                    @{
                        // Xác định khoảng trang hiển thị (tối đa 5 nút)
                        int startPage = Math.Max(1, currentPage - 2);
                        int endPage = Math.Min(totalPages, currentPage + 2);

                        // Điều chỉnh để luôn hiển thị 5 nút nếu có đủ trang
                        if (endPage - startPage < 4)
                        {
                            if (startPage == 1)
                            {
                                endPage = Math.Min(totalPages, startPage + 4);
                            }
                            else
                            {
                                startPage = Math.Max(1, endPage - 4);
                            }
                        }
                    }

                    @if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { id = catId, page = 1 })">1</a>
                        </li>
                        @if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { id = catId, page = i })">@i</a>
                        </li>
                    }

                    @if (endPage < totalPages)
                    {
                        @if (endPage < totalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { id = catId, page = totalPages })">@totalPages</a>
                        </li>
                    }

                    @{
                        // Nút Next
                        string nextUrl = Url.Action("Index", new { id = catId, page = currentPage + 1 });
                    }
                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@nextUrl" aria-label="Sau">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                </ul>
            </div>
        </nav>
    }
</div>
